<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="ItechPanel_Configurator::configurator" title="Product Customizer" sortOrder="100">
                    <resource id="ItechPanel_Configurator::section" title="Manage Sections" sortOrder="10"/>
                    <resource id="ItechPanel_Configurator::subsection" title="Manage Sub Sections" sortOrder="20"/>
                    <resource id="ItechPanel_Configurator::option" title="Manage Options" sortOrder="30"/>
                    <resource id="ItechPanel_Configurator::option_child" title="Manage Options Childs" sortOrder="40"/>
                    <resource id="ItechPanel_Configurator::option_group" title="Manage Option Group" sortOrder="50"/>
                    <resource id="ItechPanel_Configurator::image_configurator" title="Manage Image Configurator" sortOrder="60"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
