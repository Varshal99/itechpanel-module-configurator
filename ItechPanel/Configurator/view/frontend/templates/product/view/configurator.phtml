<script>
function configurator(configurationUrl, imagesUrl, calculatePriceUrl, productId, basePrice) {
    return {
        loading: false,
        configuration: null,
        sections: [],
        selectedOptions: {},
        selectedPrices: {},
        currentPrice: basePrice,
        basePrice: basePrice,

        configurationUrl: configurationUrl,
        imagesUrl: imagesUrl,
        calculatePriceUrl: calculatePriceUrl,
        productId: productId,

        currentImage: null,
        layers: {},
        activeSection: 0,

        init() {
            this.loadConfiguration();
        },

        getFormKey() {
            const match = document.cookie.match(/(?:^|;) ?form_key=([^;]*)(?:;|$)/);
            return match ? match[1] : '';
        },

        async loadConfiguration() {
            this.loading = true;
            try {
                const response = await fetch(this.configurationUrl);
                const data = await response.json();
                if (data.success) {
                    this.configuration = data.data;
                    this.sections = data.data.sections || [];
                }
            } catch (error) {
                console.error('Configuration load error:', error);
            } finally {
                this.loading = false;
            }
        },

        selectOption(optionId, childId, price) {
            if (!childId) {
                delete this.selectedOptions[optionId];
                delete this.selectedPrices[optionId];
            } else {
                this.selectedOptions[optionId] = parseInt(childId);
                this.selectedPrices[optionId] = parseFloat(price) || 0;
            }

            this.recalculatePrice();
            this.updateImages();
        },

        isSelected(optionId, childId) {
            return this.selectedOptions[optionId] === parseInt(childId);
        },

        async recalculatePrice() {
            let total = this.basePrice;
            for (let id in this.selectedPrices) {
                total += this.selectedPrices[id];
            }
            this.currentPrice = total;

            try {
                const formData = new FormData();
                formData.append('product_id', this.productId);
                formData.append('selected_options', JSON.stringify(this.selectedOptions));
                formData.append('form_key', this.getFormKey());

                const response = await fetch(this.calculatePriceUrl, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: formData
                });

                if (!response.ok) return;

                const data = await response.json();
                if (data.success) {
                    this.currentPrice = parseFloat(data.total_price);
                }
            } catch (error) {
                console.error('Price calculation error:', error);
            }
        },

        async updateImages() {
            if (Object.keys(this.selectedOptions).length === 0) {
                this.currentImage = null;
                this.layers = {};
                return;
            }

            try {
                const formData = new FormData();
                formData.append('product_id', this.productId);
                formData.append('selected_children', JSON.stringify(this.selectedOptions));
                formData.append('form_key', this.getFormKey());

                const response = await fetch(this.imagesUrl, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: formData
                });

                if (!response.ok) {
                    console.error('Image request failed:', response.status);
                    return;
                }

                const data = await response.json();

                if (data.success && data.images) {
                    this.currentImage = data.images.upload_image || null;
                    this.layers = {
						frame: data.images.frame || null,
						seat: data.images.seat || null
					};
                } else {
                    this.currentImage = null;
                    this.layers = {};
                }

            } catch (error) {
                console.error('Image update error:', error);
            }
        },

        formatPrice(price) {
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD'
            }).format(price);
        }
    }
}
</script>

