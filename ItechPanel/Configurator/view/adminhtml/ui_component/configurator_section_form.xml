<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">configurator_section_form.section_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Section Information</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="back" class="ItechPanel\Configurator\Block\Adminhtml\Section\Edit\BackButton"/>
            <button name="delete" class="ItechPanel\Configurator\Block\Adminhtml\Section\Edit\DeleteButton"/>
            <button name="save" class="ItechPanel\Configurator\Block\Adminhtml\Section\Edit\SaveButton"/>
            <button name="save_and_continue" class="ItechPanel\Configurator\Block\Adminhtml\Section\Edit\SaveAndContinueButton"/>
        </buttons>
        <namespace>configurator_section_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>configurator_section_form.section_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="section_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="configurator/section/save"/>
        </settings>
        <dataProvider class="ItechPanel\Configurator\Model\ResourceModel\Section\DataProvider" name="section_form_data_source">
            <settings>
                <requestFieldName>section_id</requestFieldName>
                <primaryFieldName>section_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    
    <fieldset name="general">
        <settings>
            <label translate="true">General Information</label>
        </settings>
        <field name="section_id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>section_id</dataScope>
            </settings>
        </field>
        <field name="title" sortOrder="10" formElement="input">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Title</label>
                <dataScope>title</dataScope>
            </settings>
        </field>
        <field name="label" sortOrder="20" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Label</label>
                <dataScope>label</dataScope>
            </settings>
        </field>
        <field name="position" sortOrder="30" formElement="input">
            <settings>
                <validation>
                    <rule name="validate-number" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Position</label>
                <dataScope>position</dataScope>
            </settings>
        </field>
        <field name="is_active" sortOrder="40" formElement="checkbox">
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Enable Section</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
    </fieldset>

    <fieldset name="assign_products" sortOrder="50">
        <settings>
            <collapsible>true</collapsible>
            <label translate="true">Assign Products</label>
        </settings>
        <container name="assign_products_container" sortOrder="160">
            <htmlContent name="html_content">
                <block name="section_products_grid" class="ItechPanel\Configurator\Block\Adminhtml\Section\AssignProducts"/>
            </htmlContent>
        </container>
    </fieldset>
</form>