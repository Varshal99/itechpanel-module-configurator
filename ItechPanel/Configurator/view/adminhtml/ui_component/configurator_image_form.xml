<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">configurator_image_form.image_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Image Information</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="back" class="ItechPanel\Configurator\Block\Adminhtml\Image\Edit\BackButton"/>
            <button name="delete" class="ItechPanel\Configurator\Block\Adminhtml\Image\Edit\DeleteButton"/>
            <button name="save" class="ItechPanel\Configurator\Block\Adminhtml\Image\Edit\SaveButton"/>
            <button name="save_and_continue" class="ItechPanel\Configurator\Block\Adminhtml\Image\Edit\SaveAndContinueButton"/>
        </buttons>
        <namespace>configurator_image_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>configurator_image_form.image_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="image_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="configurator/image/save"/>
        </settings>
        <dataProvider class="ItechPanel\Configurator\Model\ResourceModel\Image\DataProvider" name="image_form_data_source">
            <settings>
                <requestFieldName>image_id</requestFieldName>
                <primaryFieldName>image_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">General Information</label>
        </settings>
        <field name="image_id" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">image</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>image_id</dataScope>
            </settings>
        </field>
        <field name="title" sortOrder="10" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">image</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Title</label>
                <dataScope>title</dataScope>
            </settings>
        </field>
        <field name="upload_image" sortOrder="20" formElement="imageUploader">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">image</item>
                </item>
            </argument>
            <settings>
                <elementTmpl>ui/form/element/uploader/image</elementTmpl>
                <dataType>string</dataType>
                <label translate="true">Upload Image</label>
                <visible>true</visible>
                <required>false</required>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <uploaderConfig>
                            <param xsi:type="url" name="url" path="configurator/image/upload"/>
                        </uploaderConfig>
                        <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                        <maxFileSize>2097152</maxFileSize>
                    </settings>
                </imageUploader>
            </formElements>
        </field>
        <field name="top_image" sortOrder="30" formElement="imageUploader">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">image</item>
                </item>
            </argument>
            <settings>
                <elementTmpl>ui/form/element/uploader/image</elementTmpl>
                <dataType>string</dataType>
                <label translate="true">Top Image</label>
                <visible>true</visible>
                <required>false</required>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <uploaderConfig>
                            <param xsi:type="url" name="url" path="configurator/image/upload"/>
                        </uploaderConfig>
                        <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                        <maxFileSize>2097152</maxFileSize>
                    </settings>
                </imageUploader>
            </formElements>
        </field>
        <field name="bottom_image" sortOrder="40" formElement="imageUploader">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">image</item>
                </item>
            </argument>
            <settings>
                <elementTmpl>ui/form/element/uploader/image</elementTmpl>
                <dataType>string</dataType>
                <label translate="true">Bottom Image</label>
                <visible>true</visible>
                <required>false</required>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <uploaderConfig>
                            <param xsi:type="url" name="url" path="configurator/image/upload"/>
                        </uploaderConfig>
                        <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                        <maxFileSize>2097152</maxFileSize>
                    </settings>
                </imageUploader>
            </formElements>
        </field>
        <field name="left_image" sortOrder="50" formElement="imageUploader">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">image</item>
                </item>
            </argument>
            <settings>
                <elementTmpl>ui/form/element/uploader/image</elementTmpl>
                <dataType>string</dataType>
                <label translate="true">Left Image</label>
                <visible>true</visible>
                <required>false</required>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <uploaderConfig>
                            <param xsi:type="url" name="url" path="configurator/image/upload"/>
                        </uploaderConfig>
                        <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                        <maxFileSize>2097152</maxFileSize>
                    </settings>
                </imageUploader>
            </formElements>
        </field>
        <field name="right_image" sortOrder="60" formElement="imageUploader">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">image</item>
                </item>
            </argument>
            <settings>
                <elementTmpl>ui/form/element/uploader/image</elementTmpl>
                <dataType>string</dataType>
                <label translate="true">Right Image</label>
                <visible>true</visible>
                <required>false</required>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <uploaderConfig>
                            <param xsi:type="url" name="url" path="configurator/image/upload"/>
                        </uploaderConfig>
                        <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                        <maxFileSize>2097152</maxFileSize>
                    </settings>
                </imageUploader>
            </formElements>
        </field>
        <field name="front_image" sortOrder="70" formElement="imageUploader">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">image</item>
                </item>
            </argument>
            <settings>
                <elementTmpl>ui/form/element/uploader/image</elementTmpl>
                <dataType>string</dataType>
                <label translate="true">Front Image</label>
                <visible>true</visible>
                <required>false</required>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <uploaderConfig>
                            <param xsi:type="url" name="url" path="configurator/image/upload"/>
                        </uploaderConfig>
                        <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                        <maxFileSize>2097152</maxFileSize>
                    </settings>
                </imageUploader>
            </formElements>
        </field>
        <field name="back_image" sortOrder="80" formElement="imageUploader">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">image</item>
                </item>
            </argument>
            <settings>
                <elementTmpl>ui/form/element/uploader/image</elementTmpl>
                <dataType>string</dataType>
                <label translate="true">Back Image</label>
                <visible>true</visible>
                <required>false</required>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <uploaderConfig>
                            <param xsi:type="url" name="url" path="configurator/image/upload"/>
                        </uploaderConfig>
                        <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                        <maxFileSize>2097152</maxFileSize>
                    </settings>
                </imageUploader>
            </formElements>
        </field>
        <field name="is_active" sortOrder="90" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">image</item>
                    <item name="default" xsi:type="number">1</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Enable Image</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
    </fieldset>
    <fieldset name="assign_products">
        <settings>
            <collapsible>true</collapsible>
            <label translate="true">Select Products</label>
        </settings>
        <container name="assign_products_container">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="sortOrder" xsi:type="number">160</item>
                </item>
            </argument>
            <htmlContent name="html_content">
                <block name="image_products" class="ItechPanel\Configurator\Block\Adminhtml\Image\AssignProducts"/>
            </htmlContent>
        </container>
    </fieldset>
</form>
